{
  "manifest_version": 3,
  "name": "Shopping AI Helper",
  "version": "1.0.0",
  "description": "Collect reviews and AI Q&A on product pages",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://www.innisfree.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.innisfree.com/kr/ko/dp/product/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    { "resources": ["panel.html"], "matches": ["https://www.innisfree.com/*"] }
  ]
}
